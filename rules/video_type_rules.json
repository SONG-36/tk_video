    "profile_adjustments": [
      {"condition": "requires_model == true", "changes": {"buyer_seller_show": 1}},
      {"condition": "has_clear_function == true", "changes": {"selling_point": 1}},
      {"condition": "requires_large_scene == true", "changes": {"life_scenario": 1}},
      {"condition": "suitable_for_comparison == true", "changes": {"evaluation_comparison": 1}},
      {"condition": "style_sensitive == true", "changes": {"buyer_seller_show": 1, "life_scenario": 1}},
      {"condition": "product_has_packaging == true", "changes": {"unboxing": 1}},
      {"condition": "is_high_price == true", "changes": {"evaluation_comparison": 1, "selling_point": 1}},
      {"condition": "is_electronic == true", "changes": {"selling_point": 1, "evaluation_comparison": 1}}
    ],
    "execution_limits": [
      {"video_type": "unboxing", "condition": "packaging_exists", "effect": "must_not_automatically_become_top_priority"},
      {"video_type": "buyer_seller_show", "condition": "human_assets_missing", "effect": "recommended_but_not_executable"},
      {"video_type": "evaluation_comparison", "condition": "comparison_object_missing", "effect": "recommended_but_not_executable"},
      {"video_type": "life_scenario", "condition": "real_scene_assets_missing", "effect": "executable_with_scene_shooting_list"}
    ]
