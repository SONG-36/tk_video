      "2": "推荐",
      "3": "强推荐"
    },
    "video_types": {
      "life_scenario": {
        "name": "生活场景型",
        "english_name": "Life scenarios connected",
        "definition": "通过具体生活场景展示商品实际用途和价值",
        "requirements": [
          "real_life_scene_is_primary",
          "product_explanation_by_subtitle_voice_or_visual",
          "same_scene_multiple_product_angles_at_least_2_or_multiple_scenes_at_least_2"
        ],
        "suitable_products": [
          "汽车用品",
          "家居用品",
          "宠物用品",
          "户外用品",
          "厨房用品",
          "日用家电",
          "清洁工具"
        ]
      },
      "selling_point": {
        "name": "卖点讲解型",
        "english_name": "Selling points presentation",
        "definition": "围绕痛点、功能、独特优势、价格或优惠展开",
        "requirements": [
          "product_is_primary_subject",
          "high_product_screen_time_and_share",
          "at_least_2_types_of_product_information"
        ],
        "suitable_products": [
          "功能明确的小件标品",
          "3C 电子",
          "工具五金",
          "车载用品",
          "小家电",
          "美容个护电器"
        ]
      },
      "unboxing": {
        "name": "开箱直拍型",
        "english_name": "Unboxing",
        "definition": "展示打开包装、商品全貌和商品细节的全过程",
        "requirements": [
          "product_is_primary_subject",
          "details_are_clear",
          "opening_package_full_view_and_details",
          "music_subtitle_or_narration"
        ],
        "suitable_products": [
          "有包装价值的商品",
          "礼盒类商品",
          "配件丰富的商品",
          "外观精致的商品",
          "新品展示"
        ],
        "auxiliary_by_default": true
      },
      "buyer_seller_show": {
        "name": "买家卖家秀型",
        "english_name": "Buyer or Seller Show",
        "definition": "真人或身体部位实测、使用和讲解",
        "requirements": [
          "person_or_body_part_is_primary_subject",
          "human_or_body_part_appears",
          "person_describes_uses_or_tests_product",
          "detailed_product_function_or_experience"
        ],
        "suitable_products": [
          "服饰",
          "鞋子",
          "珠宝配饰",
          "美妆个护",
          "发型工具",
          "需要真人效果展示的商品",
          "需要尺寸参考的商品"
        ]
      },
      "evaluation_comparison": {
        "name": "测评对比型",
        "english_name": "Evaluation and comparison type",
        "definition": "通过同类商品或不同规格的客观对比突出差异",
        "requirements": [
          "at_least_1_comparable_product_or_variant",
          "objective_advantage_and_disadvantage_display",
          "no_obvious_bias"
        ],
        "suitable_products": [
          "同质化严重的商品",
          "功能可测试的商品",
          "参数可对比的商品",
          "购买前会横向比较的商品"
        ]
      }
    },
