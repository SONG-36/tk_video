{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "shot_asset_plan.schema.json",
  "title": "Shot Asset Plan",
  "description": "来源：00_design.md 第 7、16、18、19 章。镜头资产计划必须携带 product_series_id + variant_id + batch_id，并与来源 video_batch_plan 和 Codex 任务包完全一致。videos[].video_id 必须存在于同一批次，所有 shot 必须归属其 video 和同一 batch，路径必须位于对应系列、批次、视频目录；这些跨对象和路径关系由后续 validators 校验。第 18 章示例未展示三类 ID，本 Schema 按同章数据归属硬规则保留三类 ID。B/C 级与第 19 章的完整资产关系未裁决。",
  "type": "object",
  "required": ["shot_asset_plan"],
  "properties": {
    "shot_asset_plan": {
      "type": "object",
      "required": ["product_series_id", "variant_id", "batch_id", "videos"],
      "properties": {
        "product_series_id": {"type": "string", "minLength": 1},
        "variant_id": {"type": "string", "minLength": 1},
        "batch_id": {"type": "string", "minLength": 1},
        "videos": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/videoShotPlan"}
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "videoShotPlan": {
      "type": "object",
      "required": ["video_id", "shots"],
      "properties": {
        "video_id": {"type": "string", "minLength": 1},
        "creative_board_path": {"type": "string", "minLength": 1},
        "storyboard_path": {"type": "string", "minLength": 1},
        "shots": {
          "type": "array",
          "items": {"$ref": "#/$defs/shot"}
        }
      },
      "additionalProperties": false
    },
    "shot": {
      "type": "object",
      "required": ["shot_id", "duration", "goal", "product_visible", "input_images", "distortion_risk"],
      "properties": {
        "shot_id": {"type": "string", "minLength": 1},
        "duration": {"type": "string", "minLength": 1},
        "goal": {"enum": ["放大痛点", "展示产品", "证明卖点", "建立信任", "推动剧情", "促进转化"]},
        "video_type": {"enum": ["life_scenario", "selling_point", "unboxing", "buyer_seller_show", "evaluation_comparison"]},
        "visual_content": {"type": "string"},
        "subject_action": {"type": "string"},
        "product_visible": {"type": "boolean"},
        "product_appearance": {"type": "string"},
        "selling_point": {"type": "string"},
        "subtitle_text": {"type": "string"},
        "voiceover_text": {"type": "string"},
        "camera_movement": {"type": "string"},
        "visual_texture": {"type": "string"},
        "lighting": {"type": "string"},
        "input_images": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "reference_videos": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "product_constraints": {"type": "string"},
        "negative_prompt": {"type": "string"},
        "distortion_risk": {"type": "string", "minLength": 1},
        "output_goal": {"type": "string"}
      },
      "additionalProperties": false
    }
  },
  "x-open-issues": [
    "B/C 级精简输出与第 19 章完整资产验收要求的适用关系未裁决。",
    "第 18 章 shot_asset_plan 示例未显式展示三类 ID。"
  ],
  "additionalProperties": false
}
