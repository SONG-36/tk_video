{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "shot_asset_plan.schema.json",
  "title": "Shot Asset Plan",
  "description": "来源：00_design.md 第 7、16—21 章。镜头资产计划必须携带 product_series_id + variant_id + batch_id，并与来源 video_batch_plan 和 Codex 任务包完全一致。videos[].video_id、shot 归属、路径、产品 8 秒出现、12 秒证明及剧情/产品平衡由后续 validators 校验。Schema 只承载字段，不假装完成跨镜头时间和语义校验。B/C 级与完整资产关系未裁决。",
  "type": "object",
  "required": ["shot_asset_plan"],
  "properties": {
    "shot_asset_plan": {
      "type": "object",
      "required": ["product_series_id", "variant_id", "batch_id", "videos"],
      "properties": {
        "product_series_id": {"type": "string", "minLength": 1},
        "variant_id": {"type": "string", "minLength": 1},
        "batch_id": {"type": "string", "minLength": 1},
        "videos": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/videoShotPlan"}
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "videoShotPlan": {
      "type": "object",
      "required": ["video_id", "shots"],
      "properties": {
        "video_id": {"type": "string", "minLength": 1},
        "creative_board_path": {"type": "string", "minLength": 1},
        "storyboard_path": {"type": "string", "minLength": 1},
        "product_first_visible_time": {"type": "number", "minimum": 0, "description": "秒；必须不晚于 8 秒，由后续 validators 跨镜头校验。"},
        "product_proof_start_time": {"type": "number", "minimum": 0, "description": "秒；必须不晚于 12 秒，由后续 validators 跨镜头校验。"},
        "plot_vs_product_balance": {"type": "string", "description": "剧情不能压过产品；判定口径未定义，由后续 validators/人工确认。"},
        "text_overlay_plan": {"type": "array", "items": {"type": "object"}},
        "sound_or_voiceover_plan": {"type": "object"},
        "shots": {
          "type": "array",
          "items": {"$ref": "#/$defs/shot"}
        }
      },
      "additionalProperties": false
    },
    "shot": {
      "type": "object",
      "required": ["shot_id", "duration", "goal", "product_visible", "input_images", "distortion_risk"],
      "properties": {
        "shot_id": {"type": "string", "minLength": 1},
        "duration": {"type": "string", "minLength": 1},
        "goal": {"enum": ["放大痛点", "展示产品", "证明卖点", "建立信任", "推动剧情", "促进转化"]},
        "video_type": {"enum": ["life_scenario", "selling_point", "unboxing", "buyer_seller_show", "evaluation_comparison"]},
        "visual_content": {"type": "string"},
        "subject_action": {"type": "string"},
        "product_visible": {"type": "boolean"},
        "product_appearance": {"type": "string"},
        "selling_point": {"type": "string"},
        "subtitle_text": {"type": "string"},
        "voiceover_text": {"type": "string"},
        "camera_movement": {"type": "string"},
        "visual_texture": {"type": "string"},
        "lighting": {"type": "string"},
        "input_images": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "reference_videos": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "product_constraints": {"type": "string"},
        "negative_prompt": {"type": "string"},
        "distortion_risk": {"type": "string", "minLength": 1},
        "output_goal": {"type": "string"},
        "emotional_trigger": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "pattern_role": {"type": "string"},
        "product_first_visible_time": {"type": "number", "minimum": 0, "description": "按镜头计划记录的产品首次清晰出现秒数；跨镜头上限由 validators 校验。"},
        "product_proof_start_time": {"type": "number", "minimum": 0, "description": "按镜头计划记录的产品证明开始秒数；跨镜头上限由 validators 校验。"},
        "plot_vs_product_balance": {"type": "string", "description": "剧情与产品平衡标记，不在 Schema 中计算。"},
        "proof_scene": {"type": "string"},
        "cta_visual": {"type": "string"},
        "text_overlay_plan": {"type": "array", "items": {"type": "object"}},
        "sound_or_voiceover_plan": {"type": "object"}
      },
      "additionalProperties": false
    }
  },
  "x-open-issues": [
    "第 15、16 章 B/C 级精简输出与第 21 章完整资产验收要求的适用关系未裁决。",
    "第 20 章 shot_asset_plan 示例未显式展示三类 ID。",
    "镜头时间轴单位/连续性与 8/12 秒跨镜头计算算法未定义。",
    "plot_vs_product_balance 的确定性判定口径未定义。"
  ],
  "additionalProperties": false
}
