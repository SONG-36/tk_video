{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "video_batch_plan.schema.json",
  "title": "Video Batch Plan",
  "description": "来源：00_design.md 第 7、15、18、19 章。视频批次唯一绑定 product_series_id + variant_id + batch_id。variant_id 必须等于当前 selected_variant_id，三类 ID 必须与镜头计划和任务包一致，total_videos 必须等于 videos 实际数量，video_id 在批次内必须唯一；这些跨对象或跨数组关系由后续 validators 校验。B/C 级精简输出与第 19 章完整资产验收要求的适用关系未裁决，本 Schema 不强制把 B/C 改成完整资产。",
  "type": "object",
  "required": ["video_batch_plan"],
  "properties": {
    "video_batch_plan": {
      "type": "object",
      "required": ["batch_id", "product_series_id", "variant_id", "total_videos", "batch_goal", "default_generation_policy", "videos"],
      "properties": {
        "batch_id": {"type": "string", "minLength": 1},
        "product_series_id": {"type": "string", "minLength": 1},
        "variant_id": {"type": "string", "minLength": 1},
        "total_videos": {"type": "integer", "minimum": 3, "maximum": 5},
        "batch_goal": {"type": "string", "minLength": 1},
        "default_generation_policy": {"enum": ["1A_1B_1C", "2A_2B_1C"]},
        "videos": {
          "type": "array",
          "minItems": 3,
          "maxItems": 5,
          "items": {"$ref": "#/$defs/videoConfiguration"}
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "videoConfiguration": {
      "type": "object",
      "required": [
        "video_id",
        "video_type",
        "creative_style",
        "main_selling_point",
        "usage_scene",
        "target_pain_point",
        "generation_level",
        "generate_seedance_prompts",
        "requires_human_assets",
        "requires_product_image_lock",
        "requires_competitor_assets",
        "estimated_shot_count",
        "duration"
      ],
      "properties": {
        "video_id": {"type": "string", "minLength": 1},
        "video_type": {"enum": ["life_scenario", "selling_point", "unboxing", "buyer_seller_show", "evaluation_comparison"]},
        "creative_style": {"type": "string", "minLength": 1},
        "main_selling_point": {"type": "string", "minLength": 1},
        "usage_scene": {"type": "string", "minLength": 1},
        "target_pain_point": {"type": "string", "minLength": 1},
        "generation_level": {"enum": ["A", "B", "C"]},
        "generate_seedance_prompts": {"type": "boolean"},
        "requires_human_assets": {"type": "boolean"},
        "requires_product_image_lock": {"type": "boolean"},
        "requires_competitor_assets": {"type": "boolean"},
        "estimated_shot_count": {"type": "integer", "minimum": 0},
        "duration": {"type": "string", "minLength": 1}
      },
      "additionalProperties": false
    }
  },
  "x-open-issues": [
    "第 15、16 章的 B/C 级精简输出与第 19 章完整资产验收要求的适用关系未裁决。"
  ],
  "additionalProperties": false
}
