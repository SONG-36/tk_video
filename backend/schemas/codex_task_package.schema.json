{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "codex_task_package.schema.json",
  "title": "Codex Task Package",
  "description": "来源：00_design.md 第 17—21 章。任务包必须唯一绑定 product_series_id + variant_id + batch_id，并绑定同一上下文的前序对象、TikTok 创意要求、模式卡和商品适配结果。ID、引用、8/12 秒、剧情平衡和禁止复制语义由后续 validators 校验。B/C 级精简输出与完整资产验收要求的适用关系未裁决。",
  "type": "object",
  "required": [
    "product_series_id",
    "variant_id",
    "batch_id",
    "judgement_report",
    "material_check",
    "image_assets",
    "creative_direction",
    "video_batch_plan",
    "shot_asset_plan",
    "available_materials",
    "missing_materials",
    "do_not_invent",
    "output_root"
  ],
  "properties": {
    "product_series_id": {"type": "string", "minLength": 1},
    "variant_id": {"type": "string", "minLength": 1},
    "batch_id": {"type": "string", "minLength": 1},
    "judgement_report": {"$ref": "judgement_report.schema.json"},
    "material_check": {"$ref": "material_check.schema.json"},
    "image_assets": {"type": "array", "items": {"$ref": "image_asset.schema.json"}},
    "creative_direction": {"$ref": "creative_direction.schema.json"},
    "video_batch_plan": {"$ref": "video_batch_plan.schema.json"},
    "shot_asset_plan": {"$ref": "shot_asset_plan.schema.json"},
    "available_materials": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "missing_materials": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "do_not_invent": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "output_root": {"type": "string", "pattern": "^outputs/[^/]+/[^/]+/?$"},
    "tiktok_creative_requirements": {
      "type": "object",
      "description": "逐视频 hook、结构、留人、证明、CTA、原生风格、字幕和声音要求。正式包完整性由 validators 校验。"
    },
    "viral_pattern_cards": {
      "type": "array",
      "items": {"$ref": "#/$defs/viralPatternCard"}
    },
    "product_adapted_patterns": {
      "type": "array",
      "items": {"$ref": "#/$defs/productAdaptedPattern"}
    },
    "creative_transfer_constraints": {
      "type": "object",
      "properties": {
        "product_first_visible_max_seconds": {"const": 8},
        "product_proof_start_max_seconds": {"const": 12},
        "plot_must_not_overpower_product": {"const": true},
        "reference_pattern_not_source_copy": {"const": true}
      },
      "additionalProperties": false
    },
    "blocked_copying_behaviors": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
  },
  "$defs": {
    "viralPatternCard": {
      "type": "object",
      "required": ["pattern_id", "source_platform", "source_region", "source_category", "pattern_name", "original_context_summary", "attention_trigger", "first_3_seconds_mechanism", "retention_mechanism", "emotional_payload", "structure", "transferable_elements", "non_transferable_elements", "suitable_product_types", "risk_flags"],
      "properties": {
        "pattern_id": {"type": "string", "minLength": 1},
        "source_platform": {"type": "string", "minLength": 1},
        "source_region": {"type": "string", "minLength": 1},
        "source_category": {"type": "string", "minLength": 1},
        "source_url": {"type": "string"},
        "pattern_name": {"type": "string", "minLength": 1},
        "original_context_summary": {"type": "string", "minLength": 1},
        "attention_trigger": {"type": "array", "items": {"type": "string"}},
        "first_3_seconds_mechanism": {"type": "string", "minLength": 1},
        "retention_mechanism": {"type": "string", "minLength": 1},
        "emotional_payload": {"type": "array", "items": {"type": "string"}},
        "structure": {"type": "object"},
        "transferable_elements": {"type": "array", "items": {"type": "string"}},
        "non_transferable_elements": {"type": "array", "items": {"type": "string"}},
        "suitable_product_types": {"type": "array", "items": {"type": "string"}},
        "risk_flags": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    },
    "productAdaptedPattern": {
      "type": "object",
      "required": ["adapted_pattern_id", "source_pattern_id", "product_series_id", "variant_id", "batch_id", "video_id", "adapted_concept", "hook_type", "first_3_seconds_text", "first_3_seconds_visual", "emotional_trigger", "product_role", "proof_scene", "cta", "risk_check"],
      "properties": {
        "adapted_pattern_id": {"type": "string", "minLength": 1},
        "source_pattern_id": {"type": "string", "minLength": 1},
        "product_series_id": {"type": "string", "minLength": 1},
        "variant_id": {"type": "string", "minLength": 1},
        "batch_id": {"type": "string", "minLength": 1},
        "video_id": {"type": "string", "minLength": 1},
        "adapted_concept": {"type": "string", "minLength": 1},
        "hook_type": {"type": "string", "minLength": 1},
        "first_3_seconds_text": {"type": "string"},
        "first_3_seconds_visual": {"type": "string"},
        "emotional_trigger": {"type": "array", "items": {"type": "string"}},
        "product_role": {"type": "string", "minLength": 1},
        "proof_scene": {"type": "string", "minLength": 1},
        "cta": {"type": "string", "minLength": 1},
        "risk_check": {"type": "object"}
      },
      "additionalProperties": false
    }
  },
  "x-open-issues": [
    "第 15、16 章的 B/C 级精简输出与第 21 章完整资产验收要求的适用关系未裁决。",
    "第 20 章未给出独立 codex_task_package 完整 JSON 结构。",
    "viral_pattern_card 与 product_adapted_pattern 没有独立 Schema 和生命周期定义。",
    "8/12 秒与剧情平衡需要后续 validators，Schema 不能完成跨镜头语义校验。"
  ],
  "additionalProperties": false
}
