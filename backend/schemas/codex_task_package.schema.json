{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "codex_task_package.schema.json",
  "title": "Codex Task Package",
  "description": "来源：00_design.md 第 17—19 章。任务包必须唯一绑定 product_series_id + variant_id + batch_id，并绑定同一上下文的判断报告、材料检查、图片资产、创意方向、视频批次和镜头规划，不得成为无上下文任务包。所有前序对象的 product_series_id 与 variant_id、批次/镜头/任务包的 batch_id、输出根路径中的 ID 必须一致；这些跨文件和路径关系由后续 validators 校验。B/C 级精简输出与第 19 章完整资产验收要求的适用关系未裁决。",
  "type": "object",
  "required": [
    "product_series_id",
    "variant_id",
    "batch_id",
    "judgement_report",
    "material_check",
    "image_assets",
    "creative_direction",
    "video_batch_plan",
    "shot_asset_plan",
    "available_materials",
    "missing_materials",
    "do_not_invent",
    "output_root"
  ],
  "properties": {
    "product_series_id": {"type": "string", "minLength": 1},
    "variant_id": {"type": "string", "minLength": 1},
    "batch_id": {"type": "string", "minLength": 1},
    "judgement_report": {"$ref": "judgement_report.schema.json"},
    "material_check": {"$ref": "material_check.schema.json"},
    "image_assets": {"type": "array", "items": {"$ref": "image_asset.schema.json"}},
    "creative_direction": {"$ref": "creative_direction.schema.json"},
    "video_batch_plan": {"$ref": "video_batch_plan.schema.json"},
    "shot_asset_plan": {"$ref": "shot_asset_plan.schema.json"},
    "available_materials": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "missing_materials": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "do_not_invent": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "output_root": {"type": "string", "pattern": "^outputs/[^/]+/[^/]+/?$"}
  },
  "x-open-issues": [
    "第 15、16 章的 B/C 级精简输出与第 19 章完整资产验收要求的适用关系未裁决。",
    "第 18 章未给出独立 codex_task_package 完整 JSON 结构。"
  ],
  "additionalProperties": false
}
