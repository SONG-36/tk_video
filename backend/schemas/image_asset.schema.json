{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "image_asset.schema.json",
  "title": "Variant Image Asset",
  "description": "目标型号图片资产。product_series_id 和 variant_id 防止跨型号误用。",
  "type": "object",
  "required": ["product_series_id", "variant_id", "image_id", "file_name", "image_type", "usage", "quality", "required"],
  "properties": {
    "product_series_id": {"type": "string", "minLength": 1},
    "variant_id": {"type": "string", "minLength": 1},
    "image_id": {"type": "string", "minLength": 1},
    "file_name": {"type": "string", "minLength": 1},
    "image_type": {"enum": ["product_reference", "product_detail", "usage_scene", "before_after", "packaging", "style_reference", "motion_reference"]},
    "view_angle": {"type": "string"},
    "usage": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "quality": {"type": "string"},
    "required": {"type": "boolean"},
    "notes": {"type": "string"}
  },
  "additionalProperties": true
}
