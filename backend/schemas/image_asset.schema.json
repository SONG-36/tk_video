{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "image_asset.schema.json",
  "title": "Variant Image Asset",
  "description": "来源：00_design.md 第 7、13、18 章。目标型号图片资产。product_series_id 与 variant_id 用于防止跨型号误用，并必须对应当前系列和 selected_variant_id；该跨对象关系由后续 validators 校验。第 18 章单项示例未显式展示这两个归属字段，但同章数据归属硬规则要求型号隔离。",
  "type": "object",
  "required": [
    "product_series_id",
    "variant_id",
    "image_id",
    "file_name",
    "image_type",
    "view_angle",
    "usage",
    "quality",
    "required",
    "notes"
  ],
  "properties": {
    "product_series_id": {"type": "string", "minLength": 1},
    "variant_id": {"type": "string", "minLength": 1},
    "image_id": {"type": "string", "minLength": 1},
    "file_name": {"type": "string", "minLength": 1},
    "image_type": {"enum": ["product_reference", "product_detail", "usage_scene", "before_after", "packaging", "style_reference", "motion_reference"]},
    "view_angle": {"type": "string", "minLength": 1},
    "usage": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "quality": {"type": "string", "minLength": 1},
    "required": {"type": "boolean"},
    "notes": {"type": "string"}
  },
  "additionalProperties": false
}
