{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "product_profile.schema.json",
  "title": "Variant Product Profile",
  "description": "来源：00_design.md 第 7、18 章。目标型号商品画像。product_series_id 与 variant_id 必须指向当前系列和 selected_variant_id，该跨对象关系由后续 validators 校验。字段类型按第 18 章数据结构投影；第 7 章三档页面选项与第 18 章布尔字段的信息粒度差异尚未裁决。",
  "type": "object",
  "required": ["product_series_id", "variant_id", "product_profile"],
  "properties": {
    "product_series_id": {"type": "string", "minLength": 1},
    "variant_id": {"type": "string", "minLength": 1},
    "product_profile": {
      "type": "object",
      "required": [
        "size",
        "requires_model",
        "requires_large_scene",
        "has_clear_function",
        "style_sensitive",
        "suitable_for_comparison",
        "product_has_packaging",
        "is_electronic",
        "has_battery",
        "touches_body",
        "is_children_related",
        "is_pet_related",
        "is_food_related",
        "is_high_price",
        "selling_point_types"
      ],
      "properties": {
        "size": {"type": "string", "minLength": 1},
        "requires_model": {"type": "boolean"},
        "requires_large_scene": {"type": "boolean"},
        "has_clear_function": {"type": "boolean"},
        "style_sensitive": {"type": "boolean"},
        "suitable_for_comparison": {"type": "boolean"},
        "product_has_packaging": {"type": "boolean"},
        "is_electronic": {"type": "boolean"},
        "has_battery": {"type": "boolean"},
        "touches_body": {"type": "boolean"},
        "is_children_related": {"type": "boolean"},
        "is_pet_related": {"type": "boolean"},
        "is_food_related": {"type": "boolean"},
        "is_high_price": {"type": "boolean"},
        "selling_point_types": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
